# Legal Researcher API - Environment Variables
# =============================================
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to version control!

# Groq API Key for LLM access
GROQ_API_KEY=your_groq_api_key_here

# Firecrawl API Key for legal research scraping
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Google Gemini API Key (required for Evidence Image/Video Analysis)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# API Server Configuration
LEGAL_API_PORT=8000
LEGAL_API_HOST=0.0.0.0

# Database Configuration (optional - defaults to SQLite)
# DATABASE_URL=sqlite:///legal_system.db

# JWT Authentication (REQUIRED for production)
JWT_SECRET=your_secure_random_jwt_secret_here
JWT_EXPIRY_HOURS=24

# Security Settings
# RATE_LIMIT_PER_MINUTE=20
